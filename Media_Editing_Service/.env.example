# Media Editing Service - Environment Variables Example
# Copy to `.env` and fill in your values.

# ---- AWS Credentials ----
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
# Prefer `AWS_DEFAULT_REGION`; fallback to `AWS_REGION` if set
AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1

# ---- Service Tunables ----
# Number of concurrent render workers (CPU-bound ffmpeg uploads handled via threads)
RENDER_WORKERS=4
# Number of Chromium contexts in the browser pool
BROWSER_POOL=2
# FFmpeg video encoder (e.g., libx264, libx265)
FFMPEG_ENCODER=libx264
# Path to templates directory containing `post_template.html`
TEMPLATES_DIR=.

# ---- Optional Runtime ----
# If unset, code auto-detects /dev/shm when available
# TMP_DIR=/tmp
