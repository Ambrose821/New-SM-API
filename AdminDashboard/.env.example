# AdminDashboard - Vite/Clerk Environment Variables Example
# Copy to `.env.local` (for local dev) or `.env` and fill in your values.
# Vite only exposes variables prefixed with `VITE_`.

# ---- Clerk ----
# Required: used in `src/main.tsx`
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY

# Optional Clerk routes (if you customize auth pages)
# VITE_CLERK_SIGN_IN_URL=/sign-in
# VITE_CLERK_SIGN_UP_URL=/sign-up
# VITE_CLERK_AFTER_SIGN_IN_URL=/dashboard
# VITE_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- App Config (optional examples) ----
# VITE_API_BASE_URL=http://localhost:3000
# VITE_APP_ENV=development
