# Media Source API - Environment Variables Example
# Copy to `.env` and fill in your values.

# ---- Server ----
PORT=3000
SESSION_SECRET=keyboard cat

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/newsmapi

# ---- Openverse API ----
# Client credentials for token fetch in openVerseAuth.ts
OPENVERSE_ID=your_openverse_client_id
OPENVERSE_SECRET=your_openverse_client_secret

# ---- Pixabay API ----
# Used in pixaBayClient.ts
PIXPAY_API_KEY=your_pixabay_api_key

# ---- Gemini (Google GenAI) ----
# Used by GeminiLLMAgent in AIServices
GEMINI_API_KEY=your_gemini_api_key

# ---- fal.ai Image Generation ----
# Used in services/ImageAndVideoSource/falAIClient.ts
FAL_KEY=your_fal_api_key

# ---- Redis ----
# Used by queues/postingQueue.ts
REDIS_HOST=cache
REDIS_PORT=6379

# ---- Media Editing Service ----
# Used in services/MediaEditing/MediaEditingAgent.ts
MEDIA_EDITOR_URL=http://localhost:8000

# ---- AWS Creds ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
